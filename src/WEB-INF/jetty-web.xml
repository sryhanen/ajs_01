<Configure class="org.eclipse.jetty.webapp.WebAppContext">
  <Call name="insertHandler">
    <Arg>
      <New id="Rewrite" class="org.eclipse.jetty.rewrite.handler.RewriteHandler">
        <!-- TODO: Check these -->
        <Set name="rewriteRequestURI">
          <Property name="jetty.rewrite.rewriteRequestURI" deprecated="rewrite.rewriteRequestURI" default="true"/>
        </Set>
        <Set name="rewritePathInfo">
          <Property name="jetty.rewrite.rewritePathInfo" deprecated="rewrite.rewritePathInfo" default="false"/>
        </Set>
        <Set name="originalPathAttribute">
          <Property name="jetty.rewrite.originalPathAttribute" deprecated="rewrite.originalPathAttribute" default="requestedPath"/>
        </Set>
        <!-- /TODO -->

        <!-- Cache all static content aggressively for 3 months -->
        <Call name="addRule">
          <Arg>
            <New class="org.eclipse.jetty.rewrite.handler.HeaderPatternRule">
              <Set name="pattern">/static/*</Set>
              <Set name="name">Cache-Control</Set>
              <Set name="value">Max-Age=7776000,public</Set>
              <Set name="terminating">true</Set>
            </New>
          </Arg>
        </Call>
        <!-- /Caches -->

        <!-- TODO: Check if this is even necessary? Explicitly do not cache any api calls -->
        <Call name="addRule">
          <Arg>
            <New class="org.eclipse.jetty.rewrite.handler.HeaderPatternRule">
              <Set name="pattern">/api/*</Set>
              <Set name="name">Cache-Control</Set>
              <Set name="value">no-store</Set>
              <Set name="terminating">true</Set>
            </New>
          </Arg>
        </Call>
        <!-- /api -->

        <!-- Do not cache / or any *.html files -->
        <Call name="addRule">
          <Arg>
            <New class="org.eclipse.jetty.rewrite.handler.HeaderPatternRule">
              <Set name="pattern">/</Set>
              <Set name="name">Cache-Control</Set>
              <Set name="value">no-store</Set>
              <Set name="terminating">true</Set>
            </New>
          </Arg>
        </Call>

        <Call name="addRule">
          <Arg>
            <New class="org.eclipse.jetty.rewrite.handler.HeaderPatternRule">
              <Set name="pattern">/*.html</Set>
              <Set name="name">Cache-Control</Set>
              <Set name="value">no-store</Set>
              <Set name="terminating">true</Set>
            </New>
          </Arg>
        </Call>
        <!-- /html -->
      </New>
    </Arg>
  </Call>
</Configure>
