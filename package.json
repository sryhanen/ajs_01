  "scripts": {
    "fakeserver": "tsx ./devServer/server.ts",
    "frontend": "webpack-dev-server --hot --mode development --config webpack.config.dev.ts",
    "both": "concurrently 'yarn fakeserver' 'yarn frontend'",
    "clean": "rimraf dist && rimraf .tmp",
    "lint:watch": "esw --watch src",
    "lint:once": "eslint src",
    "dev:server": "webpack-dev-server --hot --mode development",
    "pretendprod:server": "webpack-dev-server --hot --mode production --env pretendprod=true",
    "dev": "concurrently 'yarn dev:server' 'yarn lint:watch'",
    "test:watch": "karma start karma.conf.ts --single-run=false",
    "pree2e": "webdriver-manager update --gecko false --versions.chrome=2.35",
    "pretest": "npm rebuild phantomjs-prebuilt",
    "karma-test": "karma start karma.conf.ts",
    "vitest": "vitest run"
  },
