{
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "module": "ES2015",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "sourceMap": true,
    "allowUmdGlobalAccess": true,
    "experimentalDecorators": true,
    "skipLibCheck": true
  },
  "files":[
    "./src/main.ts"
  ],
  "include": [
    "./devServer/**/*",
    "./**/*.ts"
  ],
  "exclude": [
    "./webpack.config.ts",
    "./webpack.config.dev.ts",
    "./src/test/*",
    "./**/*.spec.ts"
  ]
}
